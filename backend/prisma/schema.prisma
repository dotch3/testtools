// backend/prisma/schema.prisma
// Database schema for TestTool — 22 tables.
// All enum-like fields use FK → EnumValue instead of Prisma enums,
// so admins can customize values from the UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  // url = pooled connection (PgBouncer/Neon pooler) — used by the app at runtime.
  // Falls back to DATABASE_URL when DATABASE_POOL_URL is not set (full-local mode).
  url               = env("DATABASE_POOL_URL")
  // directUrl = direct non-pooled connection — used only by prisma migrate.
  directUrl         = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── Auth & Users ──────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String?
  avatarUrl           String?
  roleId              String
  role                Role      @relation(fields: [roleId], references: [id])
  passwordHash        String?
  emailVerified       Boolean   @default(false)
  lastLoginAt         DateTime?
  failedLoginCount    Int       @default(0)
  lockedUntil         DateTime?
  themePreference     String?   // dark | light | system
  forcePasswordChange Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  oauthAccounts    OAuthAccount[]
  projectsCreated  Project[]         @relation("ProjectCreatedBy")
  projectMembers   ProjectMember[]
  testPlansCreated TestPlan[]
  testSuitesCreated TestSuite[]
  testCasesCreated TestCase[]
  executions       TestExecution[]
  executionStepResults ExecutionStepResult[]
  etChartersCreated ETCharter[]      @relation("ETCharterCreator")
  etChartersTested ETCharter[]      @relation("ETCharterTester")
  bugsReported     Bug[]             @relation("BugReportedBy")
  bugsAssigned     Bug[]             @relation("BugAssignedTo")
  attachments      Attachment[]
  customFieldDefs  CustomFieldDef[]
  integrations     Integration[]
  auditLogs        AuditLog[]
  refreshTokens    RefreshToken[]
  passwordResets   PasswordResetToken[]
  suiteAssignees   TestSuiteAssignee[]
  caseAssignees    TestCaseAssignee[]

  @@map("users")
}

model OAuthAccount {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String    // github | google | microsoft
  providerUserId String
  accessToken    String    // encrypted with ENCRYPTION_KEY
  refreshToken   String?   // encrypted with ENCRYPTION_KEY
  scopes         String    @default("")  // space-separated OAuth scopes granted by the user
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("password_reset_tokens")
}

// ─── RBAC ──────────────────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String
  color     String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  projectMembers ProjectMember[]
  permissions    RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // project | test_plan | test_case | execution | bug | ...
  action      String   // create | read | update | delete | execute | export | import | ...
  label       String
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Enums (DB-managed) ────────────────────────────────────────────────────

model EnumType {
  id         String   @id @default(uuid())
  name       String   @unique  // execution_status | bug_priority | field_type | ...
  entityType String?
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())

  values EnumValue[]

  @@map("enum_types")
}

model EnumValue {
  id         String   @id @default(uuid())
  enumTypeId String
  enumType   EnumType @relation(fields: [enumTypeId], references: [id], onDelete: Cascade)
  systemKey  String?  // immutable internal key used by code
  value      String
  label      String
  color      String?
  icon       String?
  orderIndex Int      @default(0)
  isDefault  Boolean  @default(false)
  isSystem   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  testPlans       TestPlan[]       @relation("TestPlanStatus")
  testCasePriority  TestCase[]      @relation("TestCasePriority")
  testCaseType      TestCase[]      @relation("TestCaseType")
  executions        TestExecution[] @relation("TestExecutionStatus")
  bugStatuses       Bug[]           @relation("BugStatus")
  bugPriorities   Bug[]            @relation("BugPriority")
  bugSeverities   Bug[]            @relation("BugSeverity")
  bugSources      Bug[]            @relation("BugSource")
  integrationTypes Integration[]
  customFieldTypes CustomFieldDef[]

  @@map("enum_values")
}

// ─── Projects ──────────────────────────────────────────────────────────────

model Project {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  createdById String
  createdBy   User      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  members         ProjectMember[]
  testPlans       TestPlan[]
  bugs            Bug[]
  integrations    Integration[]
  customFieldDefs CustomFieldDef[]
  attachments     Attachment[]
  tags            Tag[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Test Management ───────────────────────────────────────────────────────

model TestPlan {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  statusId    String
  status      EnumValue @relation("TestPlanStatus", fields: [statusId], references: [id])
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  suites     TestSuite[]
  executions TestExecution[]

  @@map("test_plans")
}

model TestSuite {
  id            String     @id @default(uuid())
  testPlanId    String
  testPlan      TestPlan   @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  parentSuiteId String?
  parentSuite   TestSuite? @relation("SuiteNesting", fields: [parentSuiteId], references: [id])
  children      TestSuite[] @relation("SuiteNesting")
  name          String
  description   String?
  orderIndex    Int        @default(0)
  nextCaseNumber Int       @default(1)
  copiedFromId  String?
  createdById   String
  createdBy     User       @relation(fields: [createdById], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  cases       TestCase[]
  assignees   TestSuiteAssignee[]
  etCharters  ETCharter[]

  @@map("test_suites")
}

model ETCharter {
  id                        String    @id @default(uuid())
  suiteId                   String
  suite                     TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  charter                   String    // Nome do charter (formato: frase terminada com ponto)
  areas                     String[]  // Áreas cobradas
  startDate                 DateTime? // Data/hora de início
  testerId                  String?   // Testador designado
  tester                    User?     @relation("ETCharterTester", fields: [testerId], references: [id])
  
  // Task Breakdown
  duration                  String?   // short/normal/long
  testDesignPercentage     Int?      @default(40)
  bugInvestigationPercentage Int?    @default(30)
  sessionSetupPercentage    Int?      @default(10)
  charterVsOpportunity      Int?      @default(70)  // % de tempo no charter vs oportunidade
  
  // Dados
  dataFiles                 String[]  // Caminhos para arquivos (screenshots, recordings)
  testNotes                Json?     // [{action: string, bullets: string[]}]
  opportunities            Json?     // [{action: string, bullets: string[]}]
  
  // Resultados
  bugs                     Json?     // [{name, steps, expected, actual}]
  issues                   Json?     // [{description}]
  
  createdById              String
  createdBy                User      @relation("ETCharterCreator", fields: [createdById], references: [id])
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  linkedBugs               BugETCharter[]
  linkedTestCases          ETCharterTestCase[]
  linkedHeuristics        ETCharterHeuristic[]

  @@map("et_charters")
}

model Heuristic {
  id           String    @id @default(uuid())
  name         String
  description  String?   // Description and guidance for using this heuristic
  template     String    // Template string for writing charters
  elements     Json?    // {risk: bool, coverage: bool, time: bool, style: bool}
  examples     Json?    // [{charter: string, description: string}]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  personas         Persona[]
  linkedCharters   ETCharterHeuristic[]

  @@map("heuristics")
}

model Persona {
  id              String    @id @default(uuid())
  heuristicId     String
  heuristic       Heuristic @relation(fields: [heuristicId], references: [id], onDelete: Cascade)
  name            String    // e.g., "Admin User", "Power User", "Guest"
  description     String?   // Persona description
  characteristics Json?    // ["Full system access", "Can configure settings"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("personas")
}

model ETCharterHeuristic {
  id           String    @id @default(uuid())
  etCharterId String
  etCharter    ETCharter @relation(fields: [etCharterId], references: [id], onDelete: Cascade)
  heuristicId String
  heuristic    Heuristic @relation(fields: [heuristicId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([etCharterId, heuristicId])
  @@map("et_charter_heuristics")
}

model BugETCharter {
  id          String    @id @default(uuid())
  bugId       String
  bug         Bug      @relation(fields: [bugId], references: [id], onDelete: Cascade)
  etCharterId String
  etCharter   ETCharter @relation(fields: [etCharterId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([bugId, etCharterId])
  @@map("bug_et_charters")
}

model ETCharterTestCase {
  id           String     @id @default(uuid())
  etCharterId String
  etCharter    ETCharter @relation(fields: [etCharterId], references: [id], onDelete: Cascade)
  testCaseId   String
  testCase     TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  @@unique([etCharterId, testCaseId])
  @@map("et_charter_test_cases")
}

model TestCase {
  id                  String    @id @default(uuid())
  suiteId             String
  suite               TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  title               String
  description         String?
  preconditions       String?
  notes               String?
  steps               Json      @default("[]")  // [{order, action, expectedResult}]
  priorityId          String
  priority            EnumValue @relation("TestCasePriority", fields: [priorityId], references: [id])
  typeId              String
  type                EnumValue @relation("TestCaseType", fields: [typeId], references: [id])
  automationScriptRef String?
  externalId         String?
  copiedFromId        String?
  createdById         String
  createdBy           User      @relation(fields: [createdById], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  currentVersion      Int       @default(1)

  executions  TestExecution[]
  tags        TestCaseTag[]
  assignees   TestCaseAssignee[]
  etCharters  ETCharterTestCase[]
  versions    TestCaseVersion[]

  @@map("test_cases")
}

model TestCaseVersion {
  id                   String   @id @default(uuid())
  testCaseId           String
  testCase             TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  version              Int
  title                String
  description          String?
  preconditions        String?
  notes                String?
  steps                Json?
  priorityId           String
  typeId               String
  automationScriptRef  String?
  createdById          String
  createdAt            DateTime @default(now())

  @@unique([testCaseId, version])
  @@map("test_case_versions")
}

model TestExecution {
  id          String    @id @default(uuid())
  testCaseId  String
  testCase    TestCase  @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  testPlanId  String
  testPlan    TestPlan  @relation(fields: [testPlanId], references: [id], onDelete: Cascade)
  statusId    String
  status      EnumValue @relation("TestExecutionStatus", fields: [statusId], references: [id])
  executedById String
  executedBy  User      @relation(fields: [executedById], references: [id])
  executedAt  DateTime  @default(now())
  durationMs  Int?
  notes       String?
  ciRunId     String?
  environment String?
  platform    String?
  createdAt   DateTime  @default(now())

  bugs        BugTestExecution[]
  tags        TestExecutionTag[]
  stepResults ExecutionStepResult[]

  @@map("test_executions")
}

model ExecutionStepResult {
  id           String   @id @default(uuid())
  executionId  String
  execution    TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepOrder    Int
  status       String
  actualResult String?
  notes        String?
  executedById String
  executedBy   User     @relation(fields: [executedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("execution_step_results")
}

// ─── Bugs ──────────────────────────────────────────────────────────────────

model Bug {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testCaseId  String?
  title       String
  description String?
  statusId    String
  status      EnumValue @relation("BugStatus", fields: [statusId], references: [id])
  priorityId  String
  priority    EnumValue @relation("BugPriority", fields: [priorityId], references: [id])
  severityId  String
  severity    EnumValue @relation("BugSeverity", fields: [severityId], references: [id])
  sourceId    String
  source      EnumValue @relation("BugSource", fields: [sourceId], references: [id])
  externalId  String?
  externalUrl String?
  reportedById String
  reportedBy  User      @relation("BugReportedBy", fields: [reportedById], references: [id])
  assignedToId String?
  assignedTo  User?     @relation("BugAssignedTo", fields: [assignedToId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  syncedAt    DateTime?

  executions BugTestExecution[]
  etCharters BugETCharter[]
  tags       BugTag[]

  @@map("bugs")
}

model BugTestExecution {
  bugId       String
  bug         Bug           @relation(fields: [bugId], references: [id], onDelete: Cascade)
  executionId String
  execution   TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@id([bugId, executionId])
  @@map("bug_test_executions")
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id        String    @id @default(uuid())
  name      String
  color     String
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  testCases       TestCaseTag[]
  bugs            BugTag[]
  testExecutions  TestExecutionTag[]

  @@unique([name, projectId])
  @@map("tags")
}

model TestCaseTag {
  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([testCaseId, tagId])
  @@map("test_case_tags")
}

model BugTag {
  bugId  String
  bug    Bug   @relation(fields: [bugId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bugId, tagId])
  @@map("bug_tags")
}

model TestExecutionTag {
  executionId String
  execution   TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  tagId       String
  tag         Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([executionId, tagId])
  @@map("test_execution_tags")
}

model TestSuiteAssignee {
  suiteId String
  suite   TestSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  userId  String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([suiteId, userId])
  @@map("test_suite_assignees")
}

model TestCaseAssignee {
  testCaseId String
  testCase   TestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([testCaseId, userId])
  @@map("test_case_assignees")
}

// ─── Integrations ──────────────────────────────────────────────────────────

model Integration {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  typeId      String
  type        EnumValue @relation(fields: [typeId], references: [id])
  config      Json      @default("{}")  // {base_url, project_key, repo, ...}
  credential  String?                   // encrypted API token / PAT
  active      Boolean   @default(true)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("integrations")
}

// ─── Custom Fields ─────────────────────────────────────────────────────────

model CustomFieldDef {
  id           String    @id @default(uuid())
  projectId    String?   // null = global (applies to all projects)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType   String    // bug | test_case | test_execution | test_plan
  name         String
  label        String
  fieldTypeId  String
  fieldType    EnumValue @relation(fields: [fieldTypeId], references: [id])
  options      Json?     // ["Option A", "Option B"] for select types
  required     Boolean   @default(false)
  defaultValue String?
  orderIndex   Int       @default(0)
  createdById  String
  createdBy    User      @relation(fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  values CustomFieldValue[]

  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id                  String         @id @default(uuid())
  fieldDefinitionId   String
  fieldDefinition     CustomFieldDef @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  entityId            String         // UUID of the bug, test_case, etc. — no FK (polymorphic)
  entityType          String
  valueText           String?
  valueNumber         Decimal?
  valueDate           DateTime?
  valueJson           Json?          // for multi_select, user references
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@map("custom_field_values")
}

// ─── Attachments ───────────────────────────────────────────────────────────

model Attachment {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entityType  String   // bug | test_execution | test_case
  entityId    String   // UUID — no FK (polymorphic). Cascade handled in service layer.
  fileName    String
  fileType    String   // MIME type
  fileSizeKb  Int
  storagePath String   // relative path (local) or object key (cloud)
  uploadedById String
  uploadedBy  User     @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime @default(now())

  @@map("attachments")
}

// ─── Audit Logs ────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  payload    Json     @default("{}")
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
